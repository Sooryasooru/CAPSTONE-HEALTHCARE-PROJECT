# HAIP environment — copy to .env and fill in real values (.env is gitignored)

# Required
GEMINI_API_KEY=your-gemini-api-key-here
HAIP_JWT_SECRET=change-me-to-a-long-random-string

# Optional / legacy (SQLite + CSV used by default; set only if using Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=haip
DB_USER=haip
DB_PASSWORD=
